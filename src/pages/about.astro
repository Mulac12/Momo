---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Markdown from '@components/misc/Markdown.astro';
import Cover from '@components/Cover.astro';
import FabMenu from '@components/control/FabMenu.astro';

import { getSpec } from '@utils/content-utils';
import { siteConfig } from '@/config';
import { render } from 'astro:content';
import { uiText } from '@constants/ui-text';

const aboutPost = await getSpec('about');
if (!aboutPost) {
  throw new Error('No about post found');
}

const { Content } = await render(aboutPost);
const pageTitle = `${uiText.header.about} - ${siteConfig.title}`;
---

<MainPageLayout title={pageTitle}>
  <div class="mx-auto w-full max-w-[var(--page-width)]">
    <Cover title={uiText.cover.title.about} subTitle={uiText.cover.subTitle.about} />
    <Markdown class="mb-6 markdown-content onload-animation">
      <Content />
    </Markdown>
  </div>
  <FabMenu showBackBottom={true} />
</MainPageLayout>
